/**
 * 个人中心页样式
 */

page {
  background-color: #F5F5F5;
  min-height: 100vh;
}

.container {
  padding-bottom: 48rpx;
}

/* ==================== 登录banner ==================== */
.login-banner {
  background: linear-gradient(135deg, #FF8C38 0%, #FFB88C 100%);
  padding: 64rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.banner-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin-bottom: 24rpx;
}

.login-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.login-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 32rpx;
}

.login-btn {
  width: 400rpx;
  height: 88rpx;
  background-color: #FFFFFF;
  color: #FF8C38;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.privacy-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ==================== 用户头部（已登录） ==================== */
.user-header {
  display: flex;
  align-items: center;
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, #FF8C38 0%, #FFB88C 100%);
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  margin-right: 24rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.user-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.logout-btn {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  padding: 12rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 24rpx;
}

/* ==================== 统计数据 ==================== */
.stats-container {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 32rpx;
  background-color: #FFFFFF;
  margin-top: -40rpx;
  margin-left: 24rpx;
  margin-right: 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 600;
  color: #FF8C38;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: #E5E5E5;
}

/* ==================== 菜单区域 ==================== */
.menu-section {
  margin-top: 24rpx;
  padding: 0 24rpx;
}

.section-title {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.menu-list {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-info {
  flex: 1;
}

.menu-name {
  font-size: 28rpx;
  color: #333333;
}

.menu-badge {
  background-color: #FF4D4F;
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-right: 16rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #CCCCCC;
}

/* ==================== 底部提示 ==================== */
.footer-tip {
  text-align: center;
  padding: 48rpx 32rpx;
  font-size: 24rpx;
  color: #999999;
}
