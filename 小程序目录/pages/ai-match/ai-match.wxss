/**
 * AI匹配页样式
 */

page {
  background-color: #F5F5F5;
  min-height: 100vh;
}

.container {
  padding: 32rpx;
  padding-bottom: 64rpx;
}

/* ==================== 页面标题 ==================== */
.page-header {
  text-align: center;
  padding: 32rpx 0 48rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.page-desc {
  font-size: 28rpx;
  color: #999999;
}

/* ==================== 上传区域 ==================== */
.upload-section {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.upload-area {
  width: 600rpx;
  height: 400rpx;
  border: 3rpx dashed #DDDDDD;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.upload-text {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: #999999;
}

/* ==================== 识别中状态 ==================== */
.recognizing-section {
  position: relative;
  margin-bottom: 32rpx;
}

.preview-image {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
}

.recognizing-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.recognizing-text {
  font-size: 28rpx;
  color: #FFFFFF;
}

/* ==================== 结果区域 ==================== */
.result-section {
  animation: fadeIn 0.5s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ==================== 预览图片区域 ==================== */
.preview-section {
  position: relative;
  margin-bottom: 24rpx;
}

.reupload-btn {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  padding: 12rpx 24rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: #FFFFFF;
  font-size: 24rpx;
  border-radius: 24rpx;
}

/* ==================== AI识别结果卡片 ==================== */
.ai-result-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.ai-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.ai-info {
  display: flex;
  flex-wrap: wrap;
}

.ai-item {
  width: 50%;
  display: flex;
  margin-bottom: 12rpx;
}

.ai-label {
  font-size: 26rpx;
  color: #999999;
}

.ai-value {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.ai-value.highlight {
  color: #FF8C38;
  font-size: 32rpx;
  font-weight: 600;
}

/* ==================== 匹配结果区域 ==================== */
.match-section {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.match-count {
  font-size: 24rpx;
  color: #999999;
}

/* ==================== 匹配列表 ==================== */
.match-list {
  display: flex;
  flex-direction: column;
}

.match-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.match-item:last-child {
  border-bottom: none;
}

.match-images {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.match-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
}

.match-upload {
  border: 3rpx solid #FF8C38;
}

.match-target {
  border: 3rpx solid #E5E5E5;
}

.vs-text {
  margin: 0 24rpx;
  font-size: 28rpx;
  color: #FF8C38;
  font-weight: 600;
}

.match-info {
  margin-bottom: 16rpx;
}

.match-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.match-detail {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.match-breed {
  font-size: 24rpx;
  color: #666666;
}

.match-divider {
  margin: 0 12rpx;
  color: #CCCCCC;
}

.match-color {
  font-size: 24rpx;
  color: #666666;
}

.match-location {
  font-size: 24rpx;
  color: #999999;
}

.match-similarity {
  display: flex;
  align-items: center;
}

.similarity-bar {
  flex: 1;
  height: 12rpx;
  background-color: #F0F0F0;
  border-radius: 6rpx;
  overflow: hidden;
}

.similarity-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF8C38 0%, #FFB88C 100%);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.similarity-text {
  margin-left: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #FF8C38;
  min-width: 80rpx;
  text-align: right;
}

/* ==================== 底部说明 ==================== */
.footer-tip {
  text-align: center;
  padding: 32rpx 0;
  font-size: 24rpx;
  color: #999999;
}
