/**
 * 地图页样式
 */

page {
  height: 100vh;
  background-color: #F5F5F5;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* ==================== 导航栏 ==================== */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background-color: rgba(255, 255, 255, 0.95);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.locate-btn {
  padding: 12rpx 24rpx;
  background-color: #FF8C38;
  color: #FFFFFF;
  font-size: 26rpx;
  border-radius: 24rpx;
}

/* ==================== 地图容器 ==================== */
.map-container {
  flex: 1;
  width: 100%;
}

/* ==================== 自定义标记点 ==================== */
.custom-marker {
  position: absolute;
  transform: translate(-50%, -50%);
}

.marker-icon {
  font-size: 48rpx;
}

/* ==================== 筛选栏 ==================== */
.filter-bar {
  display: flex;
  padding: 20rpx 24rpx;
  background-color: rgba(255, 255, 255, 0.95);
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666666;
  border-radius: 32rpx;
  margin-right: 16rpx;
}

.filter-item:last-child {
  margin-right: 0;
}

.filter-item.active {
  background-color: #FF8C38;
  color: #FFFFFF;
}

/* ==================== 图例栏 ==================== */
.legend-bar {
  display: flex;
  justify-content: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background-color: rgba(255, 255, 255, 0.95);
}

.legend-item {
  display: flex;
  align-items: center;
  margin-right: 40rpx;
}

.legend-item:last-child {
  margin-right: 0;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.legend-dot.lost {
  background-color: #FF4D4F;
}

.legend-dot.found {
  background-color: #52C41A;
}

.legend-dot.adopt {
  background-color: #1890FF;
}

.legend-item text {
  font-size: 24rpx;
  color: #666666;
}

/* ==================== 弹窗遮罩 ==================== */
.popup-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.popup-content {
  width: 600rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
}

.popup-image {
  width: 100%;
  height: 300rpx;
}

.popup-info {
  padding: 24rpx;
}

.popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.popup-type {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.popup-type.type-lost {
  background-color: rgba(255, 77, 79, 0.1);
  color: #FF4D4F;
}

.popup-type.type-found {
  background-color: rgba(82, 196, 26, 0.1);
  color: #52C41A;
}

.popup-type.type-adopt {
  background-color: rgba(24, 144, 255, 0.1);
  color: #1890FF;
}

.popup-similarity {
  font-size: 26rpx;
  color: #FF8C38;
  font-weight: 500;
}

.popup-action {
  margin: 0 24rpx 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #FF8C38 0%, #FFB88C 100%);
  color: #FFFFFF;
  text-align: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.popup-close {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 48rpx;
  height: 48rpx;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 28rpx;
}
