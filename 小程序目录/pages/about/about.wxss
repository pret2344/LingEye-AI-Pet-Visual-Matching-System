/**
 * 关于页面样式
 */

page {
  background-color: #F5F5F5;
}

.container {
  min-height: 100vh;
  padding-bottom: 48rpx;
}

/* 头部 */
.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 24rpx;
  background: linear-gradient(135deg, #FF8C38 0%, #FFB88C 100%);
}

.logo {
  width: 128rpx;
  height: 128rpx;
  background-color: #FFFFFF;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.app-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.version {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 介绍 */
.intro-section {
  padding: 32rpx 24rpx;
  background-color: #FFFFFF;
  margin-bottom: 24rpx;
}

.intro-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  text-align: center;
}

/* 功能特点 */
.features-section {
  background-color: #FFFFFF;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.features-list {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.feature-item {
  width: calc(50% - 12rpx);
  display: flex;
  padding: 20rpx;
  background-color: #F5F5F5;
  border-radius: 12rpx;
}

.feature-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.feature-info {
  flex: 1;
}

.feature-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 4rpx;
}

.feature-desc {
  font-size: 22rpx;
  color: #999999;
}

/* 联系方式 */
.contact-section {
  background-color: #FFFFFF;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.contact-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.contact-info {
  flex: 1;
}

.contact-title {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 4rpx;
}

.contact-desc {
  font-size: 24rpx;
  color: #999999;
}

.contact-arrow {
  font-size: 32rpx;
  color: #CCCCCC;
}

/* 协议 */
.agreement-section {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.agreement-item {
  font-size: 26rpx;
  color: #FF8C38;
}

.agreement-divider {
  margin: 0 24rpx;
  color: #DDDDDD;
}

/* 版权 */
.copyright {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
  font-size: 22rpx;
  color: #CCCCCC;
  line-height: 1.8;
}
