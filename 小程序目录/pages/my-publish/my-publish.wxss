/**
 * 我的发布页样式
 */

page {
  background-color: #F5F5F5;
}

.container {
  min-height: 100vh;
}

.tab-bar {
  display: flex;
  background-color: #FFFFFF;
  padding: 16rpx;
  gap: 16rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.tab-item {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  color: #666666;
  background-color: #F5F5F5;
  border-radius: 32rpx;
  flex-shrink: 0;
}

.tab-item.active {
  background-color: #FF8C38;
  color: #FFFFFF;
}

.list-container {
  padding: 24rpx;
}

.list-item {
  display: flex;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.item-content {
  flex: 1;
  min-width: 0;
}

.item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.tag {
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  border-radius: 6rpx;
}

.tag-pending {
  background-color: rgba(250, 173, 20, 0.1);
  color: #FAAD14;
}

.tag-published {
  background-color: rgba(82, 196, 26, 0.1);
  color: #52C41A;
}

.tag-completed {
  background-color: rgba(24, 144, 255, 0.1);
  color: #1890FF;
}

.tag-rejected {
  background-color: rgba(255, 77, 79, 0.1);
  color: #FF4D4F;
}

.time {
  font-size: 22rpx;
  color: #999999;
}

.item-location {
  font-size: 24rpx;
  color: #666666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-actions {
  display: flex;
  flex-direction: column;
  justify-content: center;
  margin-left: 16rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border-radius: 24rpx;
}

.action-btn.delete {
  background-color: #FFF1F0;
  color: #FF4D4F;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.loading-state {
  text-align: center;
  padding: 48rpx;
  font-size: 26rpx;
  color: #999999;
}
