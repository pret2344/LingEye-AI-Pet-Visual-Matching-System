<!--pages/detail/detail.wxml-->
<!-- 信息详情页 -->

<view class="container" wx:if="{{!loading}}">
  <!-- 图片轮播 -->
  <swiper 
    class="image-swiper"
    indicator-dots
    indicator-color="rgba(255,255,255,0.5)"
    indicator-active-color="#FFFFFF"
    circular
  >
    <swiper-item 
      wx:for="{{detail.images}}" 
      wx:key="index"
      data-index="{{index}}"
      bindtap="onPreviewImage"
    >
      <image class="swiper-image" src="{{item}}" mode="aspectFill" />
    </swiper-item>
  </swiper>
  
  <!-- 内容区域 -->
  <scroll-view class="content-scroll" scroll-y>
    <!-- 状态标签 -->
    <view class="status-bar">
      <view class="status-tag tag-{{detail.type}}">
        {{detail.type === 'lost' ? '走失' : detail.type === 'found' ? '发现' : '领养'}}
      </view>
      <text class="publish-time">{{detail.createdAt}}</text>
    </view>
    
    <!-- 标题 -->
    <view class="title">{{detail.title}}</view>
    
    <!-- 基本信息 -->
    <view class="info-section">
      <view class="info-row">
        <view class="info-item">
          <text class="info-label">品种</text>
          <text class="info-value">{{detail.breed}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">毛色</text>
          <text class="info-value">{{detail.color}}</text>
        </view>
      </view>
      <view class="info-row">
        <view class="info-item">
          <text class="info-label">性别</text>
          <text class="info-value">{{detail.gender}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">年龄</text>
          <text class="info-value">{{detail.age}}</text>
        </view>
      </view>
    </view>
    
    <!-- 详细描述 -->
    <view class="desc-section">
      <view class="section-title">详细描述</view>
      <view class="desc-content">{{detail.description}}</view>
    </view>
    
    <!-- 位置信息 -->
    <view class="location-section" bindtap="onNavigateMap">
      <view class="location-icon">📍</view>
      <view class="location-info">
        <view class="location-label">位置</view>
        <view class="location-value">{{detail.location}}</view>
      </view>
      <view class="location-arrow">›</view>
    </view>
    
    <!-- 互动区 -->
    <view class="interact-section">
      <view class="section-title">留言评论</view>
      
      <!-- 评论列表 -->
      <view class="comment-list">
        <view class="comment-item" wx:for="{{comments}}" wx:key="id">
          <view class="comment-avatar">🐾</view>
          <view class="comment-content">
            <view class="comment-header">
              <text class="comment-nickname">{{item.author.nickName}}</text>
              <text class="comment-time">{{item.createdAt}}</text>
            </view>
            <view class="comment-text">{{item.content}}</view>
          </view>
        </view>
        
        <!-- 空评论 -->
        <view class="empty-comment" wx:if="{{comments.length === 0}}">
          <text>暂无评论，来说两句吧</text>
        </view>
      </view>
    </view>
    
    <!-- 底部占位 -->
    <view class="bottom-placeholder"></view>
  </scroll-view>
  
  <!-- 操作栏 -->
  <view class="action-bar">
    <view class="action-item" bindtap="onToggleFavorite">
      <view class="action-icon">{{isFavorite ? '❤️' : '🤍'}}</view>
      <view class="action-text">{{isFavorite ? '已收藏' : '收藏'}}</view>
    </view>
    <view class="action-item" bindtap="onShare">
      <view class="action-icon">📤</view>
      <view class="action-text">分享</view>
    </view>
    <view class="action-item" bindtap="onReport">
      <view class="action-icon">🚩</view>
      <view class="action-text">举报</view>
    </view>
    
    <!-- 发布者专属操作 -->
    <view class="action-btn" wx:if="{{isOwner}}" bindtap="onMarkCompleted">
      {{detail.type === 'lost' ? '标记已找到' : detail.type === 'adopt' ? '标记已领养' : '标记已处理'}}
    </view>
  </view>
  
  <!-- 评论输入框 -->
  <view class="comment-input-bar">
    <input 
      class="comment-input"
      placeholder="发表评论..."
      value="{{newComment}}"
      bindinput="onInput"
      bindconfirm="onSubmitComment"
    />
    <view class="comment-submit" bindtap="onSubmitComment">发送</view>
  </view>
</view>

<!-- 加载状态 -->
<view class="loading-container" wx:if="{{loading}}">
  <view class="loading-spinner"></view>
  <view class="loading-text">加载中...</view>
</view>
