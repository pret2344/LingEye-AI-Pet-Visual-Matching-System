/**
 * 首页样式
 */

/* 页面容器 */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #F5F5F5;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* ==================== 头部区域 ==================== */
.header {
  background-color: #FFFFFF;
  padding-bottom: 0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.location-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
}

.location-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.location-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.location-arrow {
  font-size: 22rpx;
  color: #999999;
  margin-left: 8rpx;
}

/* ==================== Tab栏 ==================== */
.tab-bar {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  height: 96rpx;
  position: relative;
  z-index: 10;
  border-bottom: 1rpx solid #F0F0F0;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  position: relative;
}

.tab-name {
  font-size: 30rpx;
  color: #666666;
  transition: all 0.3s ease;
  position: relative;
}

.tab-item.active .tab-name {
  color: #FF8C38;
  font-weight: 600;
}

.tab-line-wrapper {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 6rpx;
}

.tab-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 56rpx;
  height: 6rpx;
  background-color: #FF8C38;
  border-radius: 3rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.map-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFF5EE;
  border-radius: 50%;
  margin-left: 16rpx;
}

.map-icon {
  font-size: 32rpx;
}

/* ==================== 内容区域 ==================== */
.content-scroll {
  flex: 1;
  height: 0;
}

/* ==================== 瀑布流布局 ==================== */
.waterfall-container {
  display: flex;
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.left-column {
  padding-right: 10rpx;
}

.right-column {
  padding-left: 10rpx;
}

/* ==================== 宠物卡片 ==================== */
.pet-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.card-image-wrapper {
  width: 100%;
  height: 300rpx;
  overflow: hidden;
  background-color: #F5F5F5;
}

.card-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.card-content {
  padding: 20rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 16rpx;
}

.card-info {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.card-location-icon {
  font-size: 22rpx;
  margin-right: 8rpx;
}

.card-location-text {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  font-size: 22rpx;
  border-radius: 8rpx;
}

.card-tag.tag-lost {
  background-color: rgba(255, 77, 79, 0.1);
  color: #FF4D4F;
}

.card-tag.tag-found {
  background-color: rgba(82, 196, 26, 0.1);
  color: #52C41A;
}

.card-tag.tag-adopt {
  background-color: rgba(24, 144, 255, 0.1);
  color: #1890FF;
}

.card-time {
  font-size: 22rpx;
  color: #999999;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 32rpx;
}

/* ==================== 按钮样式 ==================== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-primary {
  background: linear-gradient(135deg, #FF8C38 0%, #FFB88C 100%);
  color: #FFFFFF;
}

.btn-small {
  width: 200rpx;
  height: 72rpx;
}

/* ==================== 加载状态 ==================== */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #F5F5F5;
  border-top-color: #FF8C38;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 24rpx;
  color: #999999;
  margin-top: 16rpx;
}

/* ==================== 没有更多 ==================== */
.no-more {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: #CCCCCC;
}

/* ==================== 底部占位 ==================== */
.bottom-placeholder {
  height: 120rpx;
}

/* ==================== 发布按钮 ==================== */
.publish-btn {
  position: fixed;
  right: 32rpx;
  bottom: calc(180rpx + env(safe-area-inset-bottom));
  width: 112rpx;
  height: 112rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FF8C38 0%, #FFB88C 100%);
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(255, 140, 56, 0.4);
  z-index: 100;
}

.publish-icon {
  font-size: 40rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.publish-text {
  font-size: 20rpx;
  color: #FFFFFF;
  margin-top: 4rpx;
}