<!--custom-tab-bar/index.wxml-->
<view class="custom-tab-bar">
  <!-- 顶部分割线 -->
  <view class="tab-bar-divider"></view>
  
  <!-- tab列表 -->
  <view class="tab-bar-content">
    <view 
      class="tab-item {{activeIndex === index ? 'active' : ''}}"
      wx:for="{{tabList}}"
      wx:key="index"
      data-index="{{index}}"
      bindtap="onTabTap"
    >
      <!-- 图标 -->
      <view class="tab-icon">
        <view class="icon-wrapper">
          <!-- 首页图标 - 房子 -->
          <svg wx:if="{{item.icon === 'home'}}" class="icon" viewBox="0 0 24 24">
            <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
          </svg>
          <!-- AI匹配图标 - 相机/图像识别 -->
          <svg wx:if="{{item.icon === 'ai'}}" class="icon" viewBox="0 0 24 24">
            <path d="M12 3L2 12h3v8h6v-6h2v6h6v-8h3L12 3zm5 15h-2v-6h-2v6h-2v-6h-2v6H7v-8l5-5 5 5v8z"/>
          </svg>
          <!-- 地图图标 - 定位标记 -->
          <svg wx:if="{{item.icon === 'map'}}" class="icon" viewBox="0 0 24 24">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
          </svg>
          <!-- 我的图标 - 用户头像 -->
          <svg wx:if="{{item.icon === 'profile'}}" class="icon" viewBox="0 0 24 24">
            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
          </svg>
        </view>
      </view>
      <!-- 文字 -->
      <text class="tab-text">{{item.text}}</text>
    </view>
  </view>
  
  <!-- 底部安全区 -->
  <view class="safe-area-bottom"></view>
</view>