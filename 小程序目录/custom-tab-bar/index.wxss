/* custom-tab-bar/index.wxss */

/* 整体容器 */
.custom-tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background-color: #FFFFFF;
}

/* 顶部分割线 */
.tab-bar-divider {
  height: 1rpx;
  background-color: #E5E5E5;
}

/* 内容区域 */
.tab-bar-content {
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 100rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

/* Tab项 */
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  transition: all 0.2s ease;
}

.tab-item:active {
  transform: scale(0.95);
}

/* 图标容器 */
.tab-icon {
  margin-bottom: 8rpx;
}

.icon-wrapper {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 图标样式 */
.icon {
  width: 40rpx;
  height: 40rpx;
  fill: #999999;
  transition: fill 0.2s ease;
}

.tab-item.active .icon {
  fill: #FF8C38;
}

/* 文字样式 */
.tab-text {
  font-size: 20rpx;
  color: #999999;
  transition: color 0.2s ease;
}

.tab-item.active .tab-text {
  color: #FF8C38;
}

/* 底部安全区 */
.safe-area-bottom {
  height: env(safe-area-inset-bottom);
}

/* 隐藏原生tabBar区域 */
page {
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
}